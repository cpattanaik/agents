{
  "mcpServers": {
    "atlassian": {
      "command": "bash",
      "args": ["${workspaceFolder}/.cursor/mcp-servers/scripts/run-atlassian-mcp.sh"],
      "cwd": "${workspaceFolder}",
      "env": {
        "ATLASSIAN_BASE_URL": "${env:ATLASSIAN_URL}",
        "ATLASSIAN_EMAIL": "${env:ATLASSIAN_EMAIL}",
        "ATLASSIAN_API_TOKEN": "${env:ATLASSIAN_API_TOKEN}"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "github-wiki": {
      "command": "bash",
      "args": ["${workspaceFolder}/.cursor/mcp-servers/scripts/run-github-wiki-mcp.sh"],
      "cwd": "${workspaceFolder}",
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      }
    }
  }
}
