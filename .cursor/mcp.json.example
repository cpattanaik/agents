{
  "mcpServers": {
    "atlassian": {
      "command": "node",
      "args": [
        ".cursor/mcp-servers/mcp-atlassian/dist/index.js"
      ],
      "env": {
        "MCP_SERVER_MODE": "true",
        "ATLASSIAN_BASE_URL": "${env:ATLASSIAN_URL}",
        "ATLASSIAN_EMAIL": "${env:ATLASSIAN_EMAIL}",
        "ATLASSIAN_API_TOKEN": "${env:ATLASSIAN_API_TOKEN}"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "github-wiki": {
      "command": "node",
      "args": [
        ".cursor/mcp-servers/github-wiki-mcp/dist/index.js"
      ],
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      }
    }
  }
}
